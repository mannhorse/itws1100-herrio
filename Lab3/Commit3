
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Oliver Herrick - Portfolio</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Orbitron:wght@400;700;900&display=swap');

        body {
            font-family: 'Orbitron', sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            color: #fff;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Arcade Cabinet Effect */
        .console {
            max-width: 1200px;
            margin: 20px auto;
            background: linear-gradient(to bottom, #0f3460, #1a1a2e);
            border: 15px solid #2d3436;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4), inset 0 0 20px rgba(255,255,255,0.1);
            padding: 20px;
        }

        /* Header/Screen */
        .screen {
            background: #0a0e27;
            border: 8px solid #00ff41;
            border-radius: 10px;
            padding: 30px;
            margin-bottom: 20px;
            box-shadow: inset 0 0 20px rgba(0,255,65,0.1);
            min-height: 150px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .screen h1 {
            font-family: 'Press Start 2P', cursive;
            font-size: 3em;
            text-align: center;
            color: #00ff41;
            text-shadow: 0 0 10px #00ff41;
            animation: flicker 0.15s infinite;
        }

        @keyframes flicker {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.95; }
        }

        /* Navigation */
        nav {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .nav-btn {
            font-family: 'Press Start 2P', cursive;
            font-size: 0.8em;
            padding: 12px 25px;
            background: #1a3a52;
            border: 4px solid #00ff41;
            border-radius: 5px;
            color: #00ff41;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 4px 0 #00ff41;
            transform: translateY(0);
            text-decoration: none;
            display: inline-block;
        }

        .nav-btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 0 #00ff41;
            background: #2d5a7a;
        }

        .nav-btn.active {
            background: #00ff41;
            color: #0a0e27;
            box-shadow: 0 0 15px #00ff41;
        }

        /* Content Areas */
        .content {
            background: #0f3460;
            border: 8px solid #00ff41;
            border-radius: 10px;
            padding: 30px;
            margin-bottom: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            display: none;
        }

        .content.active {
            display: block;
            animation: slideIn 0.4s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .content h2 {
            font-family: 'Press Start 2P', cursive;
            font-size: 2em;
            margin-bottom: 20px;
            color: #00ff41;
            text-shadow: 0 0 10px #00ff41;
        }

        .content h3 {
            font-family: 'Press Start 2P', cursive;
            font-size: 1.2em;
            margin-top: 20px;
            margin-bottom: 10px;
            color: #00ff41;
        }

        /* Cards Grid */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .card {
            background: #1a3a52;
            border: 4px solid #00ff41;
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
            transition: all 0.3s;
            cursor: pointer;
        }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 30px rgba(0,255,65,0.4);
            background: #2d5a7a;
        }

        .card h4 {
            font-family: 'Press Start 2P', cursive;
            font-size: 1em;
            margin-bottom: 10px;
            color: #00ff41;
        }

        .card p {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9em;
            line-height: 1.6;
            color: #e0e0e0;
        }

        /* Resume Styles */
        .resume-section {
            margin-bottom: 20px;
            background: rgba(0,255,65,0.05);
            padding: 15px;
            border-left: 4px solid #00ff41;
            border-radius: 5px;
        }

        .resume-section h4 {
            color: #00ff41;
            margin-bottom: 8px;
        }

        /* Contact Form */
        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 15px;
            max-width: 500px;
            margin: 0 auto;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        .form-group label {
            margin-bottom: 8px;
            color: #00ff41;
            font-family: 'Press Start 2P', cursive;
            font-size: 0.8em;
        }

        .form-group input,
        .form-group textarea {
            padding: 12px;
            border: 3px solid #00ff41;
            border-radius: 5px;
            background: #0a0e27;
            color: #00ff41;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9em;
        }

        .form-group textarea {
            resize: vertical;
            min-height: 120px;
        }

        .submit-btn {
            font-family: 'Press Start 2P', cursive;
            padding: 15px;
            background: #00ff41;
            border: 4px solid #00ff41;
            border-radius: 5px;
            color: #0a0e27;
            cursor: pointer;
            font-size: 0.8em;
            transition: all 0.3s;
            box-shadow: 0 4px 0 #00ff41;
            transform: translateY(0);
        }

        .submit-btn:hover:active {
            transform: translateY(4px);
            box-shadow: 0 0px 0 #00ff41;
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 20px;
            font-family: 'Press Start 2P', cursive;
            font-size: 0.7em;
            color: #00ff41;
            background: rgba(0,255,65,0.05);
            border-radius: 5px;
            margin-top: 20px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .screen h1 {
                font-size: 1.8em;
            }

            .content h2 {
                font-size: 1.3em;
            }

            nav {
                flex-direction: column;
            }

            .nav-btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="console">
        <div class="screen">
            <h1>OLIVER HERRICK</h1>
        </div>

        <nav>
            <button class="nav-btn active" onclick="showSection('home')">HOME</button>
            <button class="nav-btn" onclick="showSection('about')">ABOUT ME</button>
            <button class="nav-btn" onclick="showSection('labs')">LABS</button>
            <button class="nav-btn" onclick="showSection('resume')">RESUME</button>
            <button class="nav-btn" onclick="showSection('contact')">CONTACT</button>
        </nav>

        <!-- HOME -->
        <div id="home" class="content active">
            <h2>WELCOME PLAYER</h2>
            <p style="font-size: 1.1em; margin-bottom: 20px; line-height: 1.8;">
                🎮 Level up your projects with a passionate full-stack developer! 
                I create dynamic, engaging web experiences with cutting-edge technology. 
                Ready to join forces? Explore my portfolio and let's build something amazing together!
            </p>
            <div class="card-grid">
                <div class="card">
                    <h4>💻 CODING</h4>
                    <p>Full-stack development with modern frameworks and practices</p>
                </div>
                <div class="card">
                    <h4>🎨 DESIGN</h4>
                    <p>Creating beautiful, intuitive user experiences</p>
                </div>
                <div class="card">
                    <h4>🚀 INNOVATION</h4>
                    <p>Always exploring new technologies and solutions</p>
                </div>
            </div>
        </div>

        <!-- ABOUT ME -->
        <div id="about" class="content">
            <h2>ABOUT ME</h2>
            <p style="margin-bottom: 20px; line-height: 1.8;">
                Hi! I'm Oliver Herrick, a passionate developer and tech enthusiast studying at RPI. 
                I love building web applications that combine functionality with engaging user experiences.
            </p>
            <h3>SKILLS & STATS</h3>
            <div class="card-grid">
                <div class="card">
                    <h4>LANGUAGES</h4>
                    <p>HTML | CSS | JavaScript | Python | Java</p>
                </div>
                <div class="card">
                    <h4>FRAMEWORKS</h4>
                    <p>React | Node.js | Express</p>
                </div>
                <div class="card">
                    <h4>TOOLS</h4>
                    <p>Git | VS Code | Terminal</p>
                </div>
            </div>
        </div>

        <!-- LABS -->
        <div id="labs" class="content">
            <h2>LAB PROJECTS</h2>
            <p style="margin-bottom: 20px;">Check out the labs and projects I've completed during my coursework:</p>
            <div class="card-grid">
                <div class="card">
                    <h4>LAB 1</h4>
                    <p>Foundation concepts and fundamentals</p>
                </div>
                <div class="card">
                    <h4>LAB 2</h4>
                    <p>Building on core skills and techniques</p>
                </div>
                <div class="card">
                    <h4>LAB 3</h4>
                    <p>Advanced projects and applications</p>
                </div>
            </div>
        </div>

        <!-- RESUME -->
        <div id="resume" class="content">
            <h2>RESUME</h2>
            
            <div class="resume-section">
                <h4>EDUCATION</h4>
                <p><strong>Rensselaer Polytechnic Institute (RPI)</strong></p>
                <p>Pursuing degree in Computer Science</p>
            </div>

            <div class="resume-section">
                <h4>EXPERIENCE</h4>
                <p>Developing full-stack web applications and learning modern development practices</p>
            </div>

            <div class="resume-section">
                <h4>SKILLS</h4>
                <p>Web Development | JavaScript | Python | HTML/CSS | Version Control | Problem Solving</p>
            </div>

            <div class="resume-section">
                <h4>PROJECTS</h4>
                <p>Portfolio websites | Web applications | Interactive projects</p>
            </div>
        </div>

        <!-- CONTACT -->
        <div id="contact" class="content">
            <h2>GET IN TOUCH</h2>
            <p style="margin-bottom: 30px; text-align: center;">Send me a message and let's connect!</p>
            
            <form class="contact-form" onsubmit="handleSubmit(event)">
                <div class="form-group">
                    <label for="name">NAME:</label>
                    <input type="text" id="name" name="name" required>
                </div>
                <div class="form-group">
                    <label for="email">EMAIL:</label>
                    <input type="email" id="email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="message">MESSAGE:</label>
                    <textarea id="message" name="message" required></textarea>
                </div>
                <button type="submit" class="submit-btn">SEND MESSAGE</button>
            </form>
        </div>

        <div class="footer">
            <p>⭐ OLIVER HERRICK PORTFOLIO 2024 ⭐</p>
            <p style="margin-top: 10px;">GAME OVER? NO WAY! KEEP EXPLORING!</p>
        </div>
    </div>

    <script>
        function showSection(sectionId) {
            // Hide all content
            const contents = document.querySelectorAll('.content');
            contents.forEach(content => content.classList.remove('active'));

            // Show selected content
            document.getElementById(sectionId).classList.add('active');

            // Update nav buttons
            const buttons = document.querySelectorAll('.nav-btn');
            buttons.forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
        }

        function handleSubmit(event) {
            event.preventDefault();
            alert('🎮 MESSAGE RECEIVED! I\'ll get back to you soon, player!');
            event.target.reset();
        }
    </script>
</body>
</html>

